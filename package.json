{
  "name": "synapse-hms",
  "version": "1.0.1",
  "description": "Synapse HMS",
  "author": {
    "email": "muhammed916rashid@gmail.com",
    "name": "Muhammed Rashid"
  },
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "pack": "next build && electron-builder",
    "lint": "next lint",
    "electron:dev": "concurrently \"next dev\" \"wait-on tcp:3000 && electron .\"",
    "dist": "npm run electron:build",
    "electron": "electron-builder --win"
  },
  "build": {
    "appId": "com.synapsehms",
    "productName": "Synapse HMS",
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "main.js",
      "out/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/out",
        "to": "app_server",
        "filter": [
          "**/*"
        ]
      }
    ],
    "linux": {
      "target": "AppImage",
      "category": "Office"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "axios": "^1.12.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "find-free-port": "^2.0.0",
    "framer-motion": "^12.23.12",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.26.0",
    "next": "^16.2.6",
    "nookies": "^2.5.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.8",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.8",
    "react-hook-form": "^7.64.0",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.1.2",
    "serve-handler": "^6.1.6",
    "swr": "^2.3.6",
    "tailwind-merge": "^3.3.1",
    "use-debounce": "^10.1.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "electron": "^43.2.0",
    "electron-builder": "^26.4.0",
    "eslint": "^10.7.0",
    "eslint-config-next": "16.2.11",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.3.7",
    "typescript": "^5.8.2",
    "wait-on": "^9.0.3"
  },
  "resolutions": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4"
  }
}
